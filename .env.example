# ─────────────────────────────────────────────────────────────────
#  Luxe Parfum — Firebase Configuration
# ─────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your Firebase project values.
#  Without these keys the app works in offline/localStorage mode
#  (single-device only).  To enable cross-device authentication:
#
#  1. Go to https://console.firebase.google.com
#  2. Create a project (or use an existing one)
#  3. Enable "Email/Password" under Authentication → Sign-in method
#  4. Create a Firestore database (start in test mode is fine)
#  5. Register a Web app and copy the config values below
# ─────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
